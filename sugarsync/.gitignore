# SugarSync .gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
env/
venv/
.env
.venv
sugarsync-env/

# Conda
.conda/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data (keep structure, not actual patient data)
data/raw/*.xlsx
data/raw/*.csv
data/processed/*.csv
data/processed/*.pkl
data/synthetic/*.csv

# Trained models (too large for git; use git-lfs or releases)
models/*.pkl
models/*.json
models/*.ubj

# Reports & plots
reports/
*.png
*.pdf

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db
desktop.ini

# Testing
.pytest_cache/
.coverage
htmlcov/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/synthetic/.gitkeep
!models/.gitkeep
!reports/.gitkeep
!logs/.gitkeep
